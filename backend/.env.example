DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Set to your Postgres connection string (Railway injects this in staging/production)
DATABASE_URL=
# Comma-separated browser origins that may call the API (required for local Next.js dev)
CORS_ALLOWED_ORIGINS=
# Optional; if unset or empty, JWTs use DJANGO_SECRET_KEY. Do not set to a blank value.
# JWT_SIGNING_KEY=
JWT_ACCESS_LIFETIME=30
JWT_REFRESH_LIFETIME=7
SEED_SCHOOL_NAME=Paideia Demo School
SEED_ADMIN_EMAIL=admin@paideia.local
SEED_ADMIN_PASSWORD=changeme-admin
SEED_ADMIN_NAME=Demo Admin
# Public URL of the Next.js app (password-reset links in email)
PAIDEIA_WEB_ORIGIN=
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@paideia.local
